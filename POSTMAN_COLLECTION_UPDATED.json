{
  "info": {
    "name": "Car Driver MERN Backend - Complete Test Suite",
    "description": "All endpoints for the Car Driver application backend",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_email",
      "value": "test@example.com",
      "type": "string"
    },
    {
      "key": "user_password",
      "value": "password123",
      "type": "string"
    },
    {
      "key": "driver_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is valid JSON', function() {",
              "  pm.response.to.be.json;",
              "});",
              "pm.test('Response time is less than 1 second', function() {",
              "  pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "2. Register New User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201 Created', function() {",
              "  pm.response.to.have.status(201);",
              "});",
              "pm.test('Response has token', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.token).to.exist;",
              "});",
              "var jsonData = pm.response.json();",
              "if (jsonData.token) {",
              "  pm.environment.set('token', jsonData.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"name\": \"Test User {{$timestamp}}\", \"email\": \"user-{{$timestamp}}@example.com\", \"password\": \"Password123\", \"phone\": \"+1234567890\"}"
        },
        "url": {
          "raw": "{{base_url}}/auth/register",
          "host": ["{{base_url}}"],
          "path": ["auth", "register"]
        }
      }
    },
    {
      "name": "3. Login User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200 OK', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has token', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.token).to.exist;",
              "});",
              "var jsonData = pm.response.json();",
              "if (jsonData.token) {",
              "  pm.environment.set('token', jsonData.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"{{user_email}}\", \"password\": \"{{user_password}}\"}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": ["{{base_url}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "4. Get Current User (Protected)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200 OK', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has user data', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.data).to.exist;",
              "  pm.expect(jsonData.data.email).to.exist;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/auth/me",
          "host": ["{{base_url}}"],
          "path": ["auth", "me"]
        }
      }
    },
    {
      "name": "5. Update User Profile (Protected)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200 OK', function() {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"name\": \"Updated Name\", \"phone\": \"+19876543210\"}"
        },
        "url": {
          "raw": "{{base_url}}/auth/profile",
          "host": ["{{base_url}}"],
          "path": ["auth", "profile"]
        }
      }
    },
    {
      "name": "6. Get All Drivers",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200 OK', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response time is less than 1 second', function() {",
              "  pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});",
              "var jsonData = pm.response.json();",
              "if (jsonData.drivers && jsonData.drivers.length > 0) {",
              "  pm.environment.set('driver_id', jsonData.drivers[0]._id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/drivers?page=1&limit=10",
          "host": ["{{base_url}}"],
          "path": ["drivers"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      }
    },
    {
      "name": "7. Get Driver by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200 OK or 404', function() {",
              "  pm.expect([200, 404]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/drivers/{{driver_id}}",
          "host": ["{{base_url}}"],
          "path": ["drivers", "{{driver_id}}"]
        }
      }
    },
    {
      "name": "8. Search Drivers",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200 OK', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response time is less than 1 second', function() {",
              "  pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/drivers/search?search=john",
          "host": ["{{base_url}}"],
          "path": ["drivers", "search"],
          "query": [
            {
              "key": "search",
              "value": "john"
            }
          ]
        }
      }
    },
    {
      "name": "9. Create Booking (Protected)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201 Created or 400 Bad Request', function() {",
              "  pm.expect([201, 400]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"driverId\": \"{{driver_id}}\", \"startTime\": \"2026-04-10T10:00:00Z\", \"endTime\": \"2026-04-10T12:00:00Z\", \"pickupLocation\": \"123 Main St\", \"dropLocation\": \"456 Park Ave\", \"totalAmount\": 150}"
        },
        "url": {
          "raw": "{{base_url}}/bookings",
          "host": ["{{base_url}}"],
          "path": ["bookings"]
        }
      }
    },
    {
      "name": "10. Get User Bookings (Protected)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200 OK', function() {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/bookings",
          "host": ["{{base_url}}"],
          "path": ["bookings"]
        }
      }
    },
    {
      "name": "11. Logout User (Protected)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200 OK', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.environment.set('token', '');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/auth/logout",
          "host": ["{{base_url}}"],
          "path": ["auth", "logout"]
        }
      }
    }
  ]
}
